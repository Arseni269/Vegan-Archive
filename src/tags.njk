---
pagination:
  data: collections.allFilters
  size: 1
  alias: tag
permalink: /tags/{{ tag | slugify }}/
layout: base.njk
---

<link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
<div class="archive-layout">
  
  <main class="main-content">
    <h1>Posts tagged with <span style="color: #0066cc;">#{{ tag }}</span></h1>
    <p style="margin-bottom: 20px;">
      <a href="{{ '/css/styles.css' | url }}" style="text-decoration: none; color: #666; font-weight: bold;">← View All Posts</a>
    </p>

    <div class="imageboard-grid">
  {% set tagSlug = tag | slugify %}
  {% for post in collections.all %}
    {% set postAuthorSlug = post.data.author | slugify %}
    {% set hasTag = false %}
    
    {% for t in post.data.tags %}
      {% if t | slugify == tagSlug %}{% set hasTag = true %}{% endif %}
    {% endfor %}

    {% if hasTag or postAuthorSlug == tagSlug %}
      <div class="post-card">
        <div class="post-thumbnail">
          <a href="{{ '/css/styles.css' | url }}">
            <img src="{{ post.data.thumbnail | url }}" alt="{{ post.data.title }}">
          </a>
        </div>
        <div class="post-details">
          <h2 class="post-title">
            <a href="{{ '/css/styles.css' | url }}">{{ post.data.title }}</a>
          </h2>
          <h5 class="post-author">{{ post.data.author }}</h5>
          
          {% if post.data.instagram_url %}
          <div class="ig-link-container">
            <a href="{{ post.data.instagram_url }}" target="_blank" rel="noopener noreferrer" class="instagram-link">View on Instagram ↗</a>
          </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>
  </main>

  <aside class="sidebar">
    <div class="sidebar-header">
      <h2>🎯 Content Directory</h2>
      <a href="{{ '/archive/' | url }}" class="clear-all-btn">✨ Show All</a>
    </div>

    <hr class="sidebar-divider">

    <details open class="filter-group-wrapper">
    <summary class="group-title">👤 Archived Creators</summary>
    <ul class="filter-list">
      {% for slug, creator in collections.creators %}
      <li>
        <a href="{{ '/tags/' + slug + '/' | url }}" class="filter-link {% if tag | slugify == slug %}active-link{% endif %}">
          <span>{{ creator.name }}</span> <span class="item-count">{{ creator.count }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </details>

  <details open class="filter-group-wrapper">
    <summary class="group-title">⚠️ Debunking Targets</summary>
    <ul class="tag-list">
      {% for tagName, posts in collections %}
        {% if tagName == "ex-vegans" or tagName == "carnivore-diet" %}
        <li>
          <a href="{{ '/tags/' + tagName | slugify + '/' | url }}" class="tag-pill target-pill {% if tagName == tag %}active-pill{% endif %}">
            #{{ tagName }} <span class="pill-count">({{ posts | length }})</span>
          </a>
        </li>
        {% endif %}
      {% endfor %}
    </ul>
  </details>

    <details class="filter-group-wrapper">
      <summary class="group-title">⚠️ Debunking & Misinformers</summary>
      <ul class="tag-list">
        {% for tagName, posts in collections %}
          {% if tagName == "ex-vegans" or tagName == "carnivore-diet" or tagName == "media-bias" %}
          <li>
            <a href="{{ '/tags/' + tagName | slugify + '/' | url }}" class="tag-pill target-pill {% if tagName == tag %}active-pill{% endif %}">
              #{{ tagName }} <span class="pill-count">({{ posts | length }})</span>
            </a>
          </li>
          {% endif %}
        {% endfor %}
      </ul>
    </details>
  </aside>

</div>