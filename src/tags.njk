---
layout: base.njk
templateEngineOverride: njk
pagination:
  data: collections.uniqTags
  size: 1
  alias: tag
permalink: /tags/{{ tag | slugify }}/index.html
---

<link rel="stylesheet" href="/Vegan-Archive/css/styles.css">
<div class="archive-layout">
  
  <main class="main-content">
    <h1>Posts tagged with <span style="color: #0066cc;">#{{ tag }}</span></h1>
    <p style="margin-bottom: 20px;">
      <a href="/Vegan-Archive/archive/" style="text-decoration: none; color: #666; font-weight: bold;">← View All Posts</a>
    </p>

    <div class="imageboard-grid">
      {% for post in collections[tag] %}
      <div class="post-card">
        <div class="post-thumbnail">
          <a href="/Vegan-Archive{{ post.url }}">
            {% if post.data.thumbnail %}
              <img src="/Vegan-Archive{{ post.data.thumbnail }}" alt="{{ post.data.title }}" loading="lazy">
            {% else %}
              <div class="placeholder-thumb">No Image</div>
            {% endif %}
          </a>
        </div>
        <div class="post-details">
          <h2 class="post-title"><a href="/Vegan-Archive{{ post.url }}">{{ post.data.title }}</a></h2>
          <h5 class="post-author">{{ post.data.author }}</h5>
          {% if post.data.instagram_url %}
          <div class="ig-link-container">
            <a href="{{ post.data.instagram_url }}" target="_blank" rel="noopener noreferrer" class="instagram-link">View on Instagram ↗</a>
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </main>

  <aside class="sidebar">
    <div class="sidebar-header">
      <h2>🎯 Content Directory</h2>
      <a href="/Vegan-Archive/archive/" class="clear-all-btn">✨ Show All</a>
    </div>

    <hr class="sidebar-divider">

    <details open class="filter-group-wrapper">
    <summary class="group-title">🌱 Core Concepts & Topics</summary>
    <ul class="tag-list">
      {% for tagName, posts in collections %}
        {% if tagName != "all" and tagName != "posts" and tagName != "tagList" and tagName != "uniqTags" and tagName != "Uncompromised Liberation" and tagName != "Vegangelic" and tagName != "ex-vegans" and tagName != "carnivore-diet" %}
        <li>
          <a href="/Vegan-Archive/tags/{{ tagName | slugify }}/" class="tag-pill {% if tagName == tag %}active-pill{% endif %}">
            #{{ tagName }} <span class="pill-count">({{ posts | length }})</span>
          </a>
        </li>
        {% endif %}
      {% endfor %}
    </ul>
  </details>

  <details open class="filter-group-wrapper">
    <summary class="group-title">⚠️ Debunking Targets</summary>
    <ul class="tag-list">
      {% for tagName, posts in collections %}
        {% if tagName == "ex-vegans" or tagName == "carnivore-diet" %}
        <li>
          <a href="/Vegan-Archive/tags/{{ tagName | slugify }}/" class="tag-pill target-pill {% if tagName == tag %}active-pill{% endif %}">
            #{{ tagName }} <span class="pill-count">({{ posts | length }})</span>
          </a>
        </li>
        {% endif %}
      {% endfor %}
    </ul>
  </details>

    <details class="filter-group-wrapper">
      <summary class="group-title">⚠️ Debunking & Misinformers</summary>
      <ul class="tag-list">
        {% for tagName, posts in collections %}
          {% if tagName == "ex-vegans" or tagName == "carnivore-diet" or tagName == "media-bias" %}
          <li>
            <a href="/Vegan-Archive/tags/{{ tagName | slugify }}/" class="tag-pill target-pill {% if tagName == tag %}active-pill{% endif %}">
              #{{ tagName }} <span class="pill-count">({{ posts | length }})</span>
            </a>
          </li>
          {% endif %}
        {% endfor %}
      </ul>
    </details>
  </aside>

</div>