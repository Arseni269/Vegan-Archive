---
layout: base.njk
templateEngineOverride: njk
---
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />

<style>
  .back-to-archive-nav { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.4rem; color: #475569; text-decoration: none; font-size: 0.95rem; font-weight: 500; transition: color 0.2s; }
  .back-link:hover { color: #0f172a; }
  .post-layout-grid { display: grid; grid-template-columns: 2.2fr 1fr; gap: 2.5rem; align-items: start; margin-top: 1.5rem; }
  @media (max-width: 900px) { .post-layout-grid { grid-template-columns: 1fr; gap: 1.5rem; } }
  main .carousel .carousel-grid { display: flex !important; flex-wrap: wrap !important; gap: 1.5rem !important; }
  main .carousel .carousel-grid a.glightbox { flex: 1 1 calc(50% - 1.5rem) !important; min-width: 250px !important; display: block !important; text-decoration: none !important; }
  main .carousel .carousel-grid img { width: 100% !important; height: auto !important; border-radius: 8px !important; display: block !important; }
  .video-post-container { width: 100%; max-width: 640px; }
  .video-post-container video { width: 100% !important; height: auto !important; border-radius: 8px; background: #000; }
  .full-width-description { grid-column: 1 / -1; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #e2e8f0; }
  .post-markdown-content { line-height: 1.7; font-size: 1rem; color: #334155; max-width: 850px; }
  .post-markdown-content p { margin-bottom: 1.25rem; }
  .post-markdown-content a { color: #0066cc; text-decoration: underline; }
  .post-markdown-content video, .post-markdown-content img { display: none !important; }
</style>

<main class="single-post-wrapper">
  <nav class="back-to-archive-nav">
    <a href="/Vegan-Archive/archive/" class="back-link">← Back to Archive Nav</a>
  </nav>

  <header class="post-header">
    <h1>{{ title }}</h1>
  </header>

  <div class="post-layout-grid">
    <div class="carousel">
      <div class="carousel-grid" id="post-gallery">
        {% if video_path %}
          <div class="video-post-container">
            <video controls>
              <source src="/Vegan-Archive{{ video_path }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          </div>
        {% else %}
          {% set targetPath = images_folder if images_folder else page.inputPath %}
          {% set galleryData = targetPath | getImagesData %}

          {% for imgName in galleryData.files %}
            {% if "thumbnail" not in imgName and ".mp4" not in imgName and imgName != "1.png" %}
              {% set finalImgPath = galleryData.folder + "/" + imgName %}
              <a href="#" class="glightbox" data-gallery="post-slides" data-title="Slide {{ loop.index }}">
                {% image finalImgPath, "Slide " + loop.index %}
              </a>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <aside class="post-sidebar">
      <div class="sidebar-info-card" style="padding: 1.5rem; background: #f8fafc; border-radius: 8px;">
        <div class="meta-section" style="margin-bottom: 1.2rem;">
          <span class="meta-label" style="font-size: 0.8rem; color: #64748b; font-weight: 600;">Creator</span>
          <h3 style="margin: 0.2rem 0 0 0;">{{ author if author else "Unknown Creator" }}</h3>
        </div>

        <div class="meta-section" style="margin-bottom: 1.2rem;">
          <span class="meta-label" style="font-size: 0.8rem; color: #64748b; font-weight: 600;">Assigned Topics</span>
          <div style="margin-top: 0.4rem; display: flex; flex-wrap: wrap; gap: 0.4rem;">
            {% for tag in tags %}
              {% if tag != "all" and tag != "posts" %}
                <span style="background: #e2e8f0; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.85rem;">#{{ tag }}</span>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if instagram_url %}
        <div style="margin-top: 0.5rem; border-top: 1px dashed #e2e8f0; padding-top: 1.2rem;">
          <a href="{{ instagram_url }}" target="_blank" rel="noopener noreferrer" style="display: block; text-align: center; background: #dc2743; color: white; padding: 0.5rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: 600;">View on Instagram</a>
        </div>
        {% endif %}
      </div>
    </aside>

    {% if content | trim %}
      <div class="full-width-description">
        <span class="meta-label" style="display: block; margin-bottom: 1rem; font-weight: 600;">Description</span>
        <div class="post-markdown-content" id="description-content">
          {{ content | safe }}
        </div>
      </div>
    {% endif %}
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Select the post content containers
    const contents = document.querySelectorAll(".post-content, .post-markdown-content, main, article");
    
    contents.forEach(container => {
      if (!container) return;
      
      // Regular expression to discover plain text links safely
      const urlRegex = /(https?:\/\/[^\s<]+)/g;
      
      // Traverse text nodes to replace URLs with clickable hyperlinks safely
      const walk = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, null, false);
      let node;
      const nodesToReplace = [];
      
      while (node = walk.nextNode()) {
        if (node.parentElement.tagName !== 'A' && urlRegex.test(node.nodeValue)) {
          nodesToReplace.push(node);
        }
      }
      
      nodesToReplace.forEach(textNode => {
        const parent = textNode.parentElement;
        const div = document.createElement('div');
        div.innerHTML = textNode.nodeValue.replace(urlRegex, '<a href="$1" target="_blank" rel="noopener noreferrer">$1</a>');
        
        while (div.firstChild) {
          parent.insertBefore(div.firstChild, textNode);
        }
        parent.removeChild(textNode);
      });
    });
  });

  
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const postContent = document.getElementById("description-content");
    if (!postContent) return;

    // Convert raw line breaks into separate paragraphs if bundled inside single blocks
    const paragraphs = postContent.querySelectorAll("p");
    paragraphs.forEach(p => {
      // If a paragraph contains HTML line breaks, break it out into true structural paragraphs
      if (p.innerHTML.includes("<br")) {
        const structuralChunks = p.innerHTML.split(/<br\s*\/?>/);
        const fragment = document.createDocumentFragment();
        
        structuralChunks.forEach(chunk => {
          if (chunk.trim()) {
            const newP = document.createElement("p");
            newP.innerHTML = chunk.trim();
            fragment.appendChild(newP);
          }
        });
        
        p.parentNode.insertBefore(fragment, p);
        p.parentNode.removeChild(p);
      }
    });
  });
</script>